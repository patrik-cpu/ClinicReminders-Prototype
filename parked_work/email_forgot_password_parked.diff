+def build_app_link(**params: str) -> str:
+    base = current_app_base_url()
+    query = "&".join(
+        f"{key}={quote_value}"
+        for key, value in params.items()
+        if (quote_value := str(value or "").strip())
+    )
+    return f"{base}?{query}" if query else base
