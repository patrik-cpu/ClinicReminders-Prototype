+def current_app_base_url() -> str:
+    configured = str(APP_PUBLIC_BASE_URL or "").strip().rstrip("/")
+    if configured:
+        return configured
+    try:
+        base_url = getattr(st.context, "url", "")
+    except Exception:
+        base_url = ""
+    parsed = urlparse(str(base_url or ""))
+    if parsed.scheme and parsed.netloc:
